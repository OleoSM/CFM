# ================================
# CEFIMAT - .gitignore
# ================================

# ================================
# ARCHIVOS CONFIDENCIALES
# ================================

# Variables de entorno (credenciales de BD, API keys, etc.)
.env
.env.*
*.env
back-end/.env

# Configuracion con credenciales de Supabase
js/config.js

# Claves y certificados
*.key
*.pem
*.p12
*.pfx
**/credentials.json
**/*secret*

# ================================
# DEPENDENCIAS
# ================================

node_modules/
package-lock.json
yarn.lock
pnpm-lock.yaml
.npm/
.yarn/
.pnp
.pnp.js

# ================================
# SISTEMA OPERATIVO
# ================================

# Windows
Thumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# macOS
.DS_Store
._*

# Linux
*~
.Trash-*

# ================================
# IDEs Y EDITORES
# ================================

.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.idea/
*.sublime-project
*.sublime-workspace
*.code-workspace

# ================================
# ARCHIVOS TEMPORALES Y LOGS
# ================================

*.log
*.tmp
*.temp
*.swp
*.swo
.cache/
tmp/

# ================================
# BUILD Y DIST
# ================================

dist/
build/
out/
.output/

# ================================
# SCRIPTS DE UTILIDAD (no son parte del sitio)
# ================================

scripts/

# ================================
# ARCHIVOS DE RESPALDO
# ================================

*.backup
*.bak
*.old
*_backup.*

# ================================
# TESTS Y COBERTURA
# ================================

coverage/
*.lcov
.nyc_output/
test-results/

# ================================
# MANTENER ESTOS ARCHIVOS
# ================================

!.gitignore
!README.md
!package.json
!js/config.example.js
!back-end/.env.example
!back-end/README.md
!back-end/supabase-schema.sql
!back-end/access-codes-setup.sql
!back-end/fix-rls-*.sql
